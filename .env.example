# Georgia Power Dashboard — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Georgia Power login email
GP_USERNAME=you@email.com

# Your Georgia Power password
# If your password contains special characters, no quoting is needed in .env
GP_PASSWORD=yourpassword

# ── Optional ──────────────────────────────────────────────────────────────────

# Account number to use. Leave commented out to auto-select your primary account.
# Useful if you have multiple accounts and want a specific one.
# GP_ACCOUNT=8061788045

# Whether your service address is inside or outside city limits.
# This determines which Municipal Franchise Fee rate is applied.
#   inside  = 3.0701%  (default — use if your address is in an incorporated city)
#   outside = 1.1852%
# If unsure, check your GP bill or call 1-888-660-5890.
CITY_LIMITS=inside

# Port for the web dashboard (default: 3000)
# PORT=3000
