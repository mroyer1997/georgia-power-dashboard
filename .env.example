# Georgia Power Dashboard — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Georgia Power login email
GP_USERNAME=you@email.com

# Your Georgia Power password
# If your password contains special characters, no quoting is needed in .env
GP_PASSWORD=yourpassword

# ── Optional ──────────────────────────────────────────────────────────────────

# Account number to use. Leave commented out to auto-select your primary account.
# Useful if you have multiple accounts and want a specific one.
# GP_ACCOUNT=8061788045

# Whether your service address is inside or outside city limits.
# This determines which Municipal Franchise Fee rate is applied.
#   inside  = 3.0701%  (default — use if your address is in an incorporated city)
#   outside = 1.1852%
# If unsure, check your GP bill or call 1-888-660-5890.
CITY_LIMITS=inside

# Port for the web dashboard (default: 3000)
# PORT=3000

# ── Ecobee HVAC Analysis (optional) ──────────────────────────────────────────
# Download runtime CSVs from ecobee.com → My Reports and drop them in your
# GPwr folder. The server auto-detects them by thermostat name.
# If auto-detection doesn't work, set explicit filenames below.

# Thermostat 1 (Upstairs)
ECOBEE_THERM1_NAME=Upstairs
ECOBEE_THERM1_TONS=2.0
ECOBEE_THERM1_SEER=14.3
# ECOBEE_THERM1_CSV=report-532548566165-2026-03-01-to-2026-03-31.csv

# Thermostat 2 (Main Floor)
ECOBEE_THERM2_NAME=Main Floor
ECOBEE_THERM2_TONS=3.0
ECOBEE_THERM2_SEER=14.3
# ECOBEE_THERM2_CSV=report-531610667704-2026-03-01-to-2026-03-31.csv

# Shared HVAC settings
ECOBEE_BLOWER_KW=0.65          # ECM blower motor draw (gas system)
ECOBEE_EER_RATIO=0.875         # SEER-to-EER conversion factor
ECOBEE_CAL_FACTOR=1.0          # Calibration multiplier (adjust after comparing to actual bills)
# ECOBEE_CSV_DIR=.             # Folder containing Ecobee CSVs (default: current folder)

# ── Emporia EV Charger (optional) ─────────────────────────────────────────────
# Pulls daily EV charging kWh from the Emporia API via PyEmVue (Python).
# Install: pip3 install pyemvue  (or: pip3 install -r requirements.txt)
# When set, the dashboard shows an "⚡ EV" button with charging analysis
# and a cost comparison vs the standard RS-1 flat rate.

EMPORIA_USERNAME=you@email.com
EMPORIA_PASSWORD=yourpassword

# Device GID for your Emporia Smart Charger (Honda Charger = 572839).
# Run emporia_fetch.py with --help to confirm, or check the Emporia app.
EMPORIA_DEVICE_GID=572839

# Optional: override device name matching if you have multiple Emporia devices
# EMPORIA_DEVICE_NAME=Honda Charger
